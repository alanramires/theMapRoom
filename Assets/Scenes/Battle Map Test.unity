      m_Calls: []
  m_text: "\u2500\u2500 NAVIGATION \u2500\u2500\r\nHOME  Center on HQ\r\nN     Toggle
    Mini-Map\r\nRClick  Pan Camera\r\nMClick  Zoom\r\nLClick  Focus Cursor\r\n\r\n\u2500\u2500
    UNITS \u2500\u2500\r\nTAB        Cycle Units\r\nShift+TAB  Reverse Cycle\r\nShift+1-9 
    Select Item (10+)\r\n\r\n\u2500\u2500 ACTIONS \u2500\u2500\r\nENTER  Confirm\r\nESC   
    Cancel\nU      Destroy Unit\r\nR      End Turn\r\nX      Command Service (Repair
    all units on buildings)\n\r\n\u2500\u2500 UI \u2500\u2500\r\nH  Toggle Help\nI:
    Save Game\nO: Load Game\nF3: Mostra Coordenadas\nF11: Fullscreen"
  m_isRightToLeft: 0
